    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "tailwindcss": "^3.4.18",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
